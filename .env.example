# —— 阿里云百炼（STT / TTS / LLM 共用同一把 key）——
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# —— LLM（Qwen，OpenAI 兼容端点）——
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# —— STT（百炼 Paraformer 实时）——
# 阶段1本地麦16k用 paraformer-realtime-v2；阶段4接电话(8k音频)时切 paraformer-realtime-8k-v2 + 8000
STT_MODEL=paraformer-realtime-v2
STT_SAMPLE_RATE=16000

# —— TTS（百炼 CosyVoice flash，低延迟）——
TTS_MODEL=cosyvoice-v3-flash
TTS_VOICE=longxiaochun_v3
# 16k：实测唯一能干净喂给电话/微信 8k 窄带麦克风读端的写入率(16k→8k 无损整数降采样;
# 24k/48k 会被 8k 读端采成垃圾)。本地麦也适用。
TTS_SAMPLE_RATE=16000
# 语速 >1 更利落，帮助压低对话总时长
TTS_SPEECH_RATE=1.25

# —— 音频设备（阶段4来电源）——
# 留空=系统默认（阶段1-3 本地麦克风闭环）。
# 微信语音接入：先在「音频MIDI设置」建多输出(BlackHole 2ch+扬声器)、系统输出选它、系统输入选 BlackHole 16ch；
# 再把 Pipecat 输入锁 BlackHole 2ch（收访客声）、输出锁 BlackHole 16ch（回程给微信麦克风）。
AUDIO_INPUT_DEVICE=
AUDIO_OUTPUT_DEVICE=
# 问候时机：电话/微信设 true(等来电者首声再问候，否则接通方听不到引导语会乱报)；本地留空/false(启动即问候)。
GREET_ON_FIRST_SOUND=

# —— PostgreSQL（与 docker-compose.yml 对齐）——
POSTGRES_USER=voicegate
POSTGRES_PASSWORD=voicegate
POSTGRES_DB=voicegate
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# —— 企业微信群机器人 webhook ——
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx
